{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedance.local/contracts/layer1.json",
  "title": "Layer1StoryPackage",
  "description": "~1 minute narrative scope: few shots, each duration_hint_sec ≤ 15.",
  "type": "object",
  "required": ["storyboard", "script", "characters", "dialogue"],
  "properties": {
    "storyboard": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["shot_id", "visual", "duration_hint_sec"],
        "properties": {
          "shot_id": { "type": "string" },
          "visual": { "type": "string" },
          "duration_hint_sec": { "type": "number", "minimum": 0, "maximum": 15 },
          "camera_notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "script": { "type": "string" },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "voice_notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "dialogue": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["speaker", "line"],
        "properties": {
          "speaker": { "type": "string" },
          "line": { "type": "string" },
          "shot_ref": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
