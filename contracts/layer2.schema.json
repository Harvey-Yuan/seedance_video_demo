{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seedance.local/contracts/layer2.json",
  "title": "Layer2VisualAndPrompts",
  "type": "object",
  "required": ["character_image_urls", "seedance_prompts"],
  "properties": {
    "character_image_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "image_prompts_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "seedance_prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "prompt"],
        "properties": {
          "segment_id": { "type": "string" },
          "prompt": { "type": "string" },
          "image_refs": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
