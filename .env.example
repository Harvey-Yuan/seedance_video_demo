# Butterbase LLM（与 OPENAI_API_KEY 二选一即可；同时配置时优先用 Butterbase）
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_APP_ID=
BUTTERBASE_API_KEY=
BUTTERBASE_JSON_RESPONSE=false

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LAYER1_MODEL=gpt-4o-mini
LAYER2_MODEL=gpt-4o-mini
IMAGE_MODEL=
SEEDANCE_2_0_API=
SEEDANCE_ARK_BASE_URL=
SEEDANCE_VIDEO_MODEL=dreamina-seedance-2-0-260128
# 定妆（ModelArk images.generate，与 SEEDANCE_2_0_API 同密钥）
# 默认与官方 Seedream 4.0 文档一致：seedream-4-0-250828（见 BytePlus ModelArk / seedream-4.0）
MAKEUP_IMAGE_MODEL=seedream-4-0-250828
# 可选：与视频不同区域时覆盖
ARK_IMAGE_BASE_URL=
FFMPEG_PATH=ffmpeg
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PRODUCT_NOTE_ZH=
