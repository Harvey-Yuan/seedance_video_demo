# Butterbase LLM (either this pair or OPENAI_API_KEY; Butterbase wins if both set)
BUTTERBASE_API_URL=https://api.butterbase.ai
BUTTERBASE_APP_ID=
BUTTERBASE_API_KEY=
BUTTERBASE_JSON_RESPONSE=false

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LAYER1_MODEL=gpt-4o-mini
LAYER2_MODEL=gpt-4o-mini
IMAGE_MODEL=
SEEDANCE_2_0_API=
SEEDANCE_ARK_BASE_URL=
SEEDANCE_VIDEO_MODEL=dreamina-seedance-2-0-260128
# Makeup (ModelArk images.generate; same key as SEEDANCE_2_0_API)
# Default matches Seedream 4.0 docs: seedream-4-0-250828 (BytePlus ModelArk / seedream-4.0)
MAKEUP_IMAGE_MODEL=seedream-4-0-250828
# Optional: override when image region differs from video
ARK_IMAGE_BASE_URL=
FFMPEG_PATH=ffmpeg
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional product blurb for /api/health and layer3 meta (alias PRODUCT_NOTE_ZH still works)
PRODUCT_NOTE=
